exports[`marked-katex-extension display katex with substitution integral 1`] = `
"<span class="katex-display"><span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML" display="block"><semantics><mrow><mo>∫</mo><mi>g</mi><msup><mrow><mo fence="true">(</mo><msub><mi>r</mi><mn>0</mn></msub><mo>+</mo><mfrac><mi>k</mi><mi>ρ</mi></mfrac><mi>t</mi><mo fence="true">)</mo></mrow><mn>3</mn></msup><mi>d</mi><mi>t</mi><mo>=</mo><mo>∫</mo><mi>g</mi><msup><mi>u</mi><mn>3</mn></msup><mrow><mo fence="true">(</mo><mfrac><mi>ρ</mi><mi>k</mi></mfrac><mo fence="true">)</mo></mrow><mi>d</mi><mi>u</mi><mo>=</mo><mfrac><mrow><mi>g</mi><mi>ρ</mi></mrow><mi>k</mi></mfrac><mo>∫</mo><msup><mi>u</mi><mn>3</mn></msup><mi>d</mi><mi>u</mi><mo>=</mo><mfrac><mrow><mi>g</mi><mi>ρ</mi></mrow><mi>k</mi></mfrac><mo>⋅</mo><mfrac><msup><mi>u</mi><mn>4</mn></msup><mn>4</mn></mfrac><mi mathvariant="normal">.</mi></mrow><annotation encoding="application/x-tex">\\int g\\left(r_0+\\frac{k}{\\rho}t\\right)^3dt
=\\int g u^3\\left(\\frac{\\rho}{k}\\right)du
